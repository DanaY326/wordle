{
  "expo": {
    "name": "Wordo",
    "slug": "Wordo",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/W.png",
    "scheme": "wordo",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "icon": "./assets/images/W.png",
      "supportsTablet": true,
      "bundleIdentifier": "com.danayuan.wordo"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#FFFFFF",
        "foregroundImage": "./assets/images/W-android.png",
        "backgroundImage": "./assets/images/blank.png"
      },
      "icon": "./assets/images/W-android.png",
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.danayuan.wordo"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/W.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
